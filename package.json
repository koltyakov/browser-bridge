{
  "name": "@browserbridge/bbx",
  "version": "1.8.5",
  "private": false,
  "keywords": [
    "agent-tools",
    "ai-agent",
    "browser",
    "browser-automation",
    "browser-bridge",
    "chrome",
    "chrome-extension",
    "developer-tools",
    "mcp",
    "model-context-protocol",
    "native-messaging",
    "ui-debugging"
  ],
  "homepage": "https://github.com/koltyakov/browser-bridge#readme",
  "bugs": {
    "url": "https://github.com/koltyakov/browser-bridge/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/koltyakov/browser-bridge.git"
  },
  "bin": {
    "bbx": "packages/agent-client/src/cli.js",
    "bbx-daemon": "packages/native-host/bin/bridge-daemon.js",
    "bbx-install": "packages/native-host/bin/install-manifest.js",
    "bbx-mcp": "packages/mcp-server/src/bin.js"
  },
  "files": [
    "LICENSE",
    "PRIVACY.md",
    "RESPONSIBLE_USE.md",
    "README.md",
    "SECURITY.md",
    "packages/agent-client/src",
    "packages/mcp-server/src",
    "packages/native-host/bin",
    "packages/native-host/src",
    "packages/protocol/src",
    "skills/browser-bridge",
    "!**/test/**",
    "!**/*.test.*",
    "!**/*.spec.*"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "lint": "oxlint . && oxfmt --check .",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "fixture:browser": "node tests/fixtures/browser-reliability/server.mjs",
    "test:runtime": "node --import tsx --test packages/*/test/*.test.ts packages/integration-tests/*.test.ts tests/fixtures/*/*.test.ts",
    "test": "c8 node --import tsx --test packages/*/test/*.test.ts packages/integration-tests/*.test.ts tests/fixtures/*/*.test.ts",
    "coverage": "c8 report --reporter=text --reporter=text-summary",
    "coverage:review": "c8 report --reporter=json-summary && node scripts/review-coverage.mjs",
    "coverage:check": "c8 check-coverage --lines 92 --branches 83",
    "typecheck": "tsc --noEmit",
    "postinstall": "node packages/native-host/bin/postinstall.js",
    "package:extension": "node scripts/package-extension.mjs",
    "check:extension-zip": "node scripts/check-extension-zip.mjs",
    "check:release-version": "node scripts/check-release-version.mjs",
    "release:check": "npm run check:release-version && npm run lint && npm run typecheck && npm test && npm run coverage:check && npm run package:extension && npm run check:extension-zip && npm pack --dry-run",
    "prepublishOnly": "npm run check:release-version && npm run lint && npm run typecheck && npm test && npm run coverage:check",
    "status": "node packages/agent-client/src/cli.js status",
    "daemon": "node packages/native-host/bin/bridge-daemon.js",
    "install-manifest": "node packages/native-host/bin/install-manifest.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@mozilla/readability": "^0.6.0",
    "linkedom": "^0.18.13",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/chrome": "^0.2.2",
    "@types/node": "^26.1.1",
    "c8": "^12.0.0",
    "oxfmt": "^0.60.0",
    "oxlint": "^1.75.0",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2"
  },
  "overrides": {
    "@hono/node-server": "2.0.11"
  },
  "engines": {
    "node": ">=20"
  }
}
