{
  "compilerOptions": {
    "target": "ES2023",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2023", "DOM", "DOM.Iterable", "WebWorker"],
    "types": ["node", "chrome"],
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "strict": true,
    "useUnknownInCatchVariables": false,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true
  },
  "include": [
    "packages/**/*.js",
    "packages/**/*.ts",
    "packages/**/*.d.ts",
    "scripts/**/*.mjs",
    "tests/**/*.ts"
  ]
}
